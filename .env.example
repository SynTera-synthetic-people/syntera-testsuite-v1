ENVIRONMENT=development
DEBUG=false

# Local dev DB (override with real URL in your private .env)
DATABASE_URL=postgresql://synth_user:synth_pass@localhost:5435/synthdb?sslmode=require

# App security
SECRET_KEY=change-me-in-local-env
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Worker settings
BATCH_SIZE=32
NUM_WORKERS=4
LOG_LEVEL=INFO

# Optional: LLM providers (set real keys only in your private .env)
OPENAI_API_KEY=your-openai-key-here
OPENAI_MODEL=gpt-4o
ANTHROPIC_API_KEY=your-anthropic-key-here
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Optional: S3 Industry Survey bucket
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=ap-south-1
S3_INDUSTRY_BUCKET=model-training1
S3_INDUSTRY_PREFIX=Dat_for_model_Training/

# Copy this file to .env and fill in your API keys (do not commit .env with real keys)
ENVIRONMENT=development
DEBUG=false

# Database: SQLite (default) or PostgreSQL. Reports, dashboard, and test studio data are stored here.
DATABASE_URL=sqlite:///./syntera.db
# For PostgreSQL (recommended for production):
# DATABASE_URL=postgresql://user:password@localhost:5432/syntera

SECRET_KEY=your-secret-key-change-this
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
BATCH_SIZE=32
NUM_WORKERS=4
LOG_LEVEL=INFO

# Optional: for Market Research Reverse Engineering (AI-powered questionnaire reconstruction)
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4o
ANTHROPIC_API_KEY=your-anthropic-api-key
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Cost optimization (see docs/COST_OPTIMIZATION.md): tier, repair model, JSON output
# TIER=pro
# OPENAI_MODEL_BASIC=gpt-4o-mini
# ANTHROPIC_MODEL_BASIC=claude-3-5-haiku-20241022
# REPAIR_MODEL_OPENAI=gpt-4o-mini
# REPAIR_MODEL_ANTHROPIC=claude-3-5-haiku-20241022
# USE_JSON_OUTPUT=false
# LLM_CACHE_MAX_ITEMS=300
# LLM_CACHE_TTL_SEC=21600
# LLM_ALLOW_NEAR_DUPLICATE_CACHE=true
# LLM_NEAR_DUPLICATE_THRESHOLD=0.985
# LLM_MAX_CONCURRENT_HEAVY_CALLS=3
# LLM_DAILY_TOKEN_BUDGET=50000000
# Simulation runtime (section-level Q&A archetypes)
# Use payload.model to choose model per request (e.g. gpt-4o-mini / claude-3-5-haiku-20241022)
# Keep OPENAI_API_KEY / ANTHROPIC_API_KEY configured for LLM archetype generation.
# SIMULATION_DAILY_TOKEN_CAP=50000000

# Optional: for Industry Survey Reports (S3 bucket listing). Required if the bucket is private.
AWS_ACCESS_KEY_ID=your-AWS-api-key
AWS_SECRET_ACCESS_KEY=your-AWS-secret-api-key
AWS_REGION=your-AWS-region
S3_INDUSTRY_BUCKET=your-S3-bucket-name
S3_INDUSTRY_PREFIX=your-S3-bucket-prefix
