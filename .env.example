# Copy to ".env" in the project root and edit (never commit .env with real secrets).
# Full local setup: docs/INSTALLATION.md

ENVIRONMENT=development
DEBUG=false

# Required: PostgreSQL (see docs/INSTALLATION.md — Docker example below)
DATABASE_URL=postgresql://syntera:password@127.0.0.1:5432/syntera
# If you use deployment/docker-compose.yml "db" service only, the URL above matches default compose credentials.

# Required for JWT auth
SECRET_KEY=change-me-to-a-long-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

BATCH_SIZE=32
NUM_WORKERS=4
LOG_LEVEL=INFO

# Optional: Market research reverse engineering + simulation LLM features
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514
OPENAI_FIRST=true
TIER=pro

# Optional: Industry surveys (private S3 bucket listing)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
S3_INDUSTRY_BUCKET=model-training1
S3_INDUSTRY_PREFIX=Dat_for_model_Training/

# Optional: cost / LLM tuning (see docs/COST_OPTIMIZATION.md if present)
# USE_JSON_OUTPUT=false
# LLM_CACHE_MAX_ITEMS=300
# LLM_CACHE_TTL_SEC=21600
